# Absolute path to this repository on the deployment host.
PATROLBOT_ROOT=/home/ubuntu/patrolbot-repo

# Use a unique tag for each deployed revision.
PATROLBOT_IMAGE=patrolbot:jazzy-revision
PATROLBOT_REVISION=git-commit-sha

# Hardware bridge endpoint used by docker/patrolbot-status.
PATROLBOT_SBC_HOST=10.0.0.1
PATROLBOT_SBC_PORT=7272
