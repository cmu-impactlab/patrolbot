<?xml version="1.0"?>
<launch>
    <!-- Use $(env NAME DEFAULT) to replace $(optenv NAME DEFAULT) -->
    <arg name="port" default="$(env PATROLBOT_PORT 172.20.87.231:7000)" />

    <node pkg="rosaria2" exec="rosaria2_debug" name="rosaria">
        <!-- Use $(var NAME) to reference arguments in ROS 2 XML -->
        <param name="seria_port" value="$(var port)" />
	<param name="publish_aria_lasers" value="false" />
        <!-- <param name="laser_port" value="/dev/ttyLIDAR" />
        <param name="laser_baud" value="38400" /> -->
    </node>
</launch>
